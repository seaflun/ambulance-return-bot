WEB_HOST=0.0.0.0
WEB_PORT=8080
ARTIFACTS_DIR=artifacts

# NAS task center mode. NAS does not run Selenium or persist plaintext portal passwords.
TASK_EXECUTION_MODE=worker_queue
DESKTOP_FAST_MODE=auto
DESKTOP_WEB_HOST=127.0.0.1
DESKTOP_WEB_PORT=8090
DESKTOP_WEB_OPEN_BROWSER=true
CASE_LOOKUP_SCHEDULER_ENABLED=false

# Generate a random value of at least 32 bytes and copy the same token to NAS and the public-duty PC worker.
# Credential relay files are sealed at rest with this token. Rotating it invalidates any pending relay record.
# This is not end-to-end transport encryption: use a trusted private LAN, Tailscale, or HTTPS.
WORKER_TOKEN=
# Separate password required when the NAS admin page triggers a public-PC update.
REMOTE_UPDATE_ADMIN_TOKEN=
# Token used by the SinpoSmart credential relay and backend event receiver through NAS.
CREDENTIAL_SYNC_TOKEN=
CREDENTIAL_SYNC_TTL_SECONDS=900

# Public-duty PC worker. Use the NAS LAN IP from the public-duty network.
WORKER_SERVER_URL=http://10.30.65.30:8080
WORKER_ID=public-duty-pc
WORKER_POLL_SECONDS=10
WORKER_API_TIMEOUT_SECONDS=8
# Statuses are written to a durable local FIFO before posting to the NAS.
WORKER_STATUS_POST_RETRIES=1
WORKER_STATUS_RETRY_BACKOFF_SECONDS=30
WORKER_STATUS_FLUSH_MAX_EVENTS=20
WORKER_STATUS_CLAIM_LEASE_SECONDS=30
# Keep this comfortably below the NAS task-claim lease (currently 15 minutes).
WORKER_CLAIM_HEARTBEAT_SECONDS=240
REMOTE_UPDATE_IDLE_SECONDS=120
CASE_LOOKUP_INTERVAL_SECONDS=1800
WORKER_USE_LOCAL_CHROME=true
WORKER_RUN_ONCE=false
WORKER_STARTUP_LAUNCHER_ENABLED=true
WORKER_GUI_START_MINIMIZED=true
CHROME_PROFILE_EMAIL=
SELENIUM_PROFILE_ROOT=%LOCALAPPDATA%\ambulance_return_bot
SELENIUM_PROFILE_CLEANUP_MAX_AGE_HOURS=4
WORKER_BROWSER_AUTO_CLOSE_SECONDS=600
MANUAL_TASK_LOCK_HEARTBEAT_SECONDS=30
# Legacy only. New installs should not depend on a fixed chrome_profile folder.
# CHROME_PROFILE_DIR=%LOCALAPPDATA%\ambulance_return_bot\chrome_profile

# Credential sync stores accounts under this public-duty package's local_data folder automatically.

# Worker-only AI captcha support. Keep the key only on the public-duty PC.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini

# LINE Messaging API, optional.
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_TO_USER_ID=
LINE_TO_USER_IDS=

# Local Chrome options for the public-duty PC worker.
USE_LOCAL_SELENIUM=true
SELENIUM_REMOTE_URL=
SELENIUM_BROWSER=chromium
SELENIUM_DETACH=true
SELENIUM_SET_WINDOW_SIZE=false
OPEN_LOCAL_BROWSER_ON_RUN=false
BROWSER_OPEN_DELAY_SECONDS=0.4
SAVE_DUTY_WORK_LOG=true
SAVE_VEHICLE_MILEAGE=true
SAVE_CONSUMABLES_RECORD=true
SAVE_DISINFECTION_RECORD=true
