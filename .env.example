WEB_HOST=0.0.0.0
WEB_PORT=8080
ARTIFACTS_DIR=artifacts

# NAS task center mode. NAS does not run Selenium and does not store portal passwords.
TASK_EXECUTION_MODE=worker_queue
CASE_LOOKUP_SCHEDULER_ENABLED=false

# Generate a random value and copy the same token to NAS and the public-duty PC worker.
WORKER_TOKEN=

# Public-duty PC worker. Use the NAS LAN IP from the public-duty network.
WORKER_SERVER_URL=http://10.30.65.30:8080
WORKER_ID=public-duty-pc
WORKER_POLL_SECONDS=10
CASE_LOOKUP_INTERVAL_SECONDS=300
WORKER_USE_LOCAL_CHROME=true
WORKER_RUN_ONCE=false
CHROME_PROFILE_EMAIL=sinpo666@gmail.com
CHROME_PROFILE_DIR=artifacts/chrome_profile

# Worker-only AI captcha support. Keep the key only on the public-duty PC.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini

# LINE Messaging API, optional.
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_TO_USER_ID=
LINE_TO_USER_IDS=

# Local Chrome options for the public-duty PC worker.
USE_LOCAL_SELENIUM=true
SELENIUM_REMOTE_URL=
SELENIUM_BROWSER=chromium
SELENIUM_DETACH=true
SELENIUM_SET_WINDOW_SIZE=false
OPEN_LOCAL_BROWSER_ON_RUN=false
BROWSER_OPEN_DELAY_SECONDS=0.4
