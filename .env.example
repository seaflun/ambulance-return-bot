WEB_HOST=0.0.0.0
WEB_PORT=8080
ARTIFACTS_DIR=artifacts

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_TO_USER_ID=
LINE_TO_USER_IDS=

# Website credentials, kept on server side only.
PPE_ACCOUNT=
PPE_PASSWORD=
DUTY_ACCOUNT=
DUTY_PASSWORD=
NFA_ACCOUNT=
NFA_PASSWORD=
EMM_ACCOUNT=
EMM_PASSWORD=

# Selenium. Use empty value for local Chrome, or the NAS Selenium container URL.
SELENIUM_REMOTE_URL=
SELENIUM_TIMEOUT_SECONDS=60
SELENIUM_REMOTE_READY_TIMEOUT_SECONDS=180
CASE_LOOKUP_INTERVAL_SECONDS=300
CASE_LOOKUP_SCHEDULER_ENABLED=true

# Local desktop operation. When true, pressing Run from the web page opens the four sites
# on the computer that is running this Flask server.
USE_LOCAL_SELENIUM=true
SELENIUM_DETACH=true
OPEN_LOCAL_BROWSER_ON_RUN=true
BROWSER_OPEN_DELAY_SECONDS=0.4
